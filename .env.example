# Mapbox (maps, geocoding, non-transit routing)
MAPBOX_SECRET_TOKEN=sk.your_mapbox_secret_token_here
# Client-side token for interactive map rendering
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Google Maps Platform (transit routing, venue search, photos)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# PostgreSQL database connection
DATABASE_URL=postgres://user:password@host:5432/database
